 to store key->node mapping\n        self.head = Node(0, 0)  # Dummy head node\n        self.tail = Node(0, 0)  # Dummy tail node\n        self.head.next = self.tail\n        self.tail.prev = self.head\n\n    def _add_node(self, node):\n        # Add a new node right after the head\n        node.prev = self.head"}
